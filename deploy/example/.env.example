# --- Required ---

# Postgres connection used by the API container. The hostname
# `excalimore-db` is the docker compose service name; do not change it
# unless you also rename the service in docker-compose.yml.
DATABASE_URL=postgres://excalimore:CHANGE_ME@excalimore-db:5432/excalimore

# Postgres password. Must match the password embedded in DATABASE_URL.
DB_PASSWORD=CHANGE_ME

# 32+ random bytes used to sign sessions. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=replace-with-32-random-bytes-hex

# Public-facing URL the browser uses (no trailing slash). Drives the
# bootstrap signup link printed at first start, plus invite-link URLs.
PUBLIC_URL=https://excalimore.example.com

# --- Optional (defaults shown) ---

# Container image tag. Pin to a specific version (e.g. v0.2.0) in production.
TAG=latest

# Host ports. Only bind to 127.0.0.1 if you front this with a reverse proxy.
WEB_PORT=8080
API_PORT=8081

# Rate limit (requests/minute/IP) for /api/auth/login and /api/auth/signup.
RATE_LIMIT_LOGIN=5

# Session cookie max-age in seconds (30 days).
SESSION_MAX_AGE=2592000

# Bootstrap-token TTL in seconds (1 hour). The first-run admin must
# claim the printed signup URL within this window.
BOOTSTRAP_TOKEN_TTL=3600
